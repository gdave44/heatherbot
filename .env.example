# =============================================================================
# HeatherBot Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Telegram credentials (from https://my.telegram.org) ---
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Admin Telegram user ID (your personal account numeric ID)
ADMIN_USER_ID=0

# --- Persona ---
# Filename of the persona YAML to load from /app/config (e.g. my_persona.yaml)
HEATHER_PERSONA=persona_example.yaml

# --- LLM / AI services ---
# Set these to point at your containerized or networked services.
# Defaults fall back to localhost ports if unset.
MODEL=dolphin-llama3:8b
LLM_URL=http://ollama:11434
TTS_URL=http://kokoro:8000
IMG_URL=http://ollama:11434
COMFYUI_URL=http://comfyui:8188

# Path to face source image inside the container (place the file in your config volume)
COMFYUI_FACE_IMAGE=/app/config/heather_face.png

# --- Payment bot (optional — for Telegram Stars tipping) ---
PAYMENT_BOT_TOKEN=
PAYMENT_BOT_USERNAME=YourPaymentBot

# --- Monitoring dashboard ---
# Auth key for the Flask dashboard at port 8888. Leave empty for open access.
MONITOR_AUTH_TOKEN=change_me_to_something_secret

# --- Debugging ---
# Set to 1 to enable full message pipeline tracing in breadcrumb.log
BREADCRUMB_LOGGING=0
