# =============================================================================
# HeatherBot Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Telegram ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Admin Telegram user ID (your personal account numeric ID)
ADMIN_USER_ID=0

# --- Persona ---
# Filename of the persona YAML to load from /app/config (e.g. my_persona.yaml)
HEATHER_PERSONA=persona_example.yaml

# --- LLM / AI services ---
# Set these to point at your containerized or networked services.
# Defaults fall back to localhost ports if unset.
MODEL=dolphin-llama3:8b
LLM_URL=http://ollama:11434
TTS_URL=http://kokoro:8000
IMG_URL=http://ollama:11434
COMFYUI_URL=http://comfyui:8188

# ComfyUI workflow and face image (files must be placed in your config volume)
COMFYUI_WORKFLOW_FILE=/app/config/workflow_flux.json
COMFYUI_FACE_IMAGE=/app/config/heather_face.png

# --- Photo caps ---
# Max photos the bot will send per user within the rolling time window
PHOTO_CAP=5
# Rolling window size in hours (resets count after this period)
PHOTO_CAP_WINDOW_HOURS=2

# --- Context-triggered spontaneous photos ---
# When the conversation mentions the character's vehicle, locations, hangouts,
# or activities, the bot will spontaneously send a related selfie.
# Fires randomly between CONTEXT_PHOTO_MIN_MSGS and CONTEXT_PHOTO_MAX_MSGS
# chat turns (independent per user), then resets to a new random threshold.
CONTEXT_PHOTO_MIN_MSGS=25
CONTEXT_PHOTO_MAX_MSGS=50

# --- Monitoring dashboard ---
# Comma-separated list of IPs or CIDR ranges allowed to access the dashboard.
# Use 0.0.0.0/0 to allow all (not recommended).
MONITOR_ALLOWED_IPS=127.0.0.1,::1

# --- Payment bot (optional — for Telegram Stars tipping) ---
# Set TIPS_ENABLED=0 to suppress all tip nudges until the payment system is configured.
# The /hubaloo admin cheat command works regardless of this setting.
TIPS_ENABLED=1
PAYMENT_BOT_TOKEN=
PAYMENT_BOT_USERNAME=YourPaymentBot

# --- Debugging ---
# Set to 1 to enable full message pipeline tracing in breadcrumb.log
# Also logs incoming chats, AI replies, and ComfyUI prompts when enabled.
BREADCRUMB_LOGGING=0
